rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Open rules so the live game works even when Firebase Anonymous Auth
    // is not enabled yet. Re-lock to request.auth != null after enabling
    // Authentication → Anonymous and adding your Vercel domain.

    match /roomCodes/{code} {
      allow read, write: if true;
    }

    match /rooms/{roomId} {
      allow read, write: if true;

      match /players/{playerId} {
        allow read, write: if true;
      }

      match /secrets/{playerId} {
        allow read, write: if true;
      }

      match /state/{docId} {
        allow read, write: if true;
      }

      match /votes/{playerId} {
        allow read, write: if true;
      }

      match /nightActions/{playerId} {
        allow read, write: if true;
      }

      match /logs/{logId} {
        allow read, write: if true;
      }

      match /hostLogs/{logId} {
        allow read, write: if true;
      }

      match /voicePeers/{peerId} {
        allow read, write: if true;
      }

      match /voiceSignals/{signalId} {
        allow read, write: if true;
      }
    }

    match /matchHistory/{matchId} {
      allow read, write: if true;
    }

    match /statistics/{uid} {
      allow read, write: if true;
    }
  }
}
