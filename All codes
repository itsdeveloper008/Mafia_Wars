  gap: 0.6rem;
  box-shadow: 0 12px 28px rgba(0, 0, 0, 0.45);
  border: 1px solid rgba(148, 163, 184, 0.45);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.hero-godfather {
  border-top: 3px solid #f97316;
}

.hero-godfather:hover {
  box-shadow: 0 0 18px rgba(249, 115, 22, 0.5);
  transform: scale(1.04);
}

.hero-mafias {
  border-top: 3px solid #991b1b;
}

.hero-mafias:hover {
  box-shadow: 0 0 18px rgba(153, 27, 27, 0.5);
  transform: scale(1.04);
}

.hero-grandma {
  border-top: 3px solid #e11d48;
}

.hero-grandma:hover {
  box-shadow: 0 0 18px rgba(225, 29, 72, 0.5);
  transform: scale(1.04);
}

.hero-civilians {
  border-top: 3px solid #22c55e;
}

.hero-civilians:hover {
  box-shadow: 0 0 18px rgba(34, 197, 94, 0.5);
  transform: scale(1.04);
}

.hero-card-inner-glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 60px;
  border-radius: 20px 20px 0 0;
  pointer-events: none;
}

.hero-glow-godfather {
  background: linear-gradient(to bottom, rgba(249, 115, 22, 0.12), transparent);
}

.hero-glow-mafia {
  background: linear-gradient(to bottom, rgba(153, 27, 27, 0.12), transparent);
}

.hero-glow-grandma {
  background: linear-gradient(to bottom, rgba(225, 29, 72, 0.12), transparent);
}

.hero-glow-civilian {
  background: linear-gradient(to bottom, rgba(34, 197, 94, 0.12), transparent);
}

.landing-progress {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 3;
  height: 3px;
  background: rgba(249, 115, 22, 0.2);
  overflow: hidden;
}

.landing-progress::after {
  content: '';
  display: block;
  height: 100%;
  width: 0;
  background: #f97316;
  animation: landing-progress-fill 5s linear forwards;
}

@keyframes landing-progress-fill {
  to {
    width: 100%;
  }
}

.hero-text h1 {
  font-size: 3rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin: 0 0 0.5rem;
}

.hero-text .hero-title,
.landing-content .hero-title {
  font-size: 5rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  background: linear-gradient(to right, #f97316, #ffffff);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  text-shadow: 0 0 40px rgba(249, 115, 22, 0.4);
  margin: 0 0 0.5rem;
}

.hero-title-divider {
  width: 120px;
  height: 1px;
  background: linear-gradient(90deg, #f97316, #fbbf24);
  margin: 0 0 0.75rem;
}

.tagline {
  margin: 0 0 0.75rem;
  font-size: 1.05rem;
  color: #e5e7eb;
}

.landing .tagline {
  font-size: 1.15rem;
  color: #f3f4f6;
}

.hint {
  margin: 0;
  color: #9ca3af;
  font-size: 0.9rem;
}

.hint-fade-in {
  color: #6b7280;
  animation: hint-fade-in 1.5s ease-out 0.5s forwards;
  opacity: 0;
}

@keyframes hint-fade-in {
  to {
    opacity: 1;
  }
}

.avatar-circle {
  width: 64px;
  height: 64px;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  border: 2px solid rgba(15, 23, 42, 0.9);
}

.landing .avatar-pulse-wrap {
  position: relative;
}

.landing .avatar-pulse-wrap::before {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: 999px;
  border: 2px solid rgba(255, 255, 255, 0.5);
  animation: avatar-pulse-ring 2.5s ease-in-out infinite;
  pointer-events: none;
}

@keyframes avatar-pulse-ring {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 0; transform: scale(1.15); }
}

.landing .hero-art .avatar-circle {
  width: 72px;
  height: 72px;
}

.avatar-circle.godfather {
  background: radial-gradient(circle at top, #f97316, #7f1d1d);
}

.avatar-circle.mafia {
  background: radial-gradient(circle at top, #991b1b, #020617);
}

.avatar-circle.grandma {
  background: radial-gradient(circle at top, #e11d48, #1f2937);
}

.avatar-circle.civilian {
  background: radial-gradient(circle at top, #22c55e, #064e3b);
}

.avatar-circle.small {
  width: 32px;
  height: 32px;
  font-size: 0.85rem;
}

.label {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: #9ca3af;
}

.field-row {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  margin-bottom: 0.9rem;
}

.field-row.inline {
  flex-direction: row;
  align-items: center;
}

.field-row label {
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: #9ca3af;
}

input {
  border-radius: 999px;
  border: 1px solid rgba(148, 163, 184, 0.6);
  background: rgba(15, 23, 42, 0.9);
  color: #f9fafb;
  padding: 0.6rem 0.9rem;
  font-size: 0.95rem;
  outline: none;
  transition:
    border-color 0.16s ease-out,
    box-shadow 0.16s ease-out,
    background 0.16s ease-out;
  flex: 1;
}

input::placeholder {
  color: #6b7280;
}

input:focus {
  border-color: #f97316;
  box-shadow: 0 0 0 1px rgba(248, 113, 22, 0.6);
}

.players-section {
  margin-top: 0.25rem;
}

.players-list {
  margin-top: 0.75rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.player-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.25rem 0.7rem 0.25rem 0.35rem;
  border-radius: 999px;
  background: rgba(15, 23, 42, 0.95);
  border: 1px solid rgba(148, 163, 184, 0.7);
}

.player-pill .name {
  font-size: 0.9rem;
}

.options-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}

.toggle-group {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.toggle-group label {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.9rem;
  color: #e5e7eb;
}

.toggle-group input[type='checkbox'] {
  width: auto;
}

.helper {
  color: #9ca3af;
  font-size: 0.9rem;
  margin: 0.15rem 0 0;
}

.helper.tiny {
  font-size: 0.78rem;
}

.room-options h2 {
  margin: 0 0 0.4rem;
}

.code-display {
  font-size: 0.9rem;
  margin-top: 0.4rem;
}

.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 1rem;
}

.card-role {
  position: relative;
  height: 190px;
  perspective: 1100px;
  cursor: pointer;
}

.card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transform-style: preserve-3d;
  transition: transform 0.5s ease;
}

.card-inner.flipped {
  transform: rotateY(180deg);
}

.card-face {
  position: absolute;
  inset: 0;
  border-radius: 18px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  backface-visibility: hidden;
  border: 1px solid rgba(148, 163, 184, 0.6);
}

.card-face.back {
  background: radial-gradient(circle at top, #111827, #020617);
  overflow: hidden;
}

.card-back-image {
  width: 100%;
  height: 100%;
  object-fit: contain; /* show full image without cutting top/bottom */
  border-radius: 18px;
}

.mafia-back {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.3rem;
}

.logo-letter {
  font-size: 2.7rem;
  font-weight: 800;
  letter-spacing: 0.2em;
}

.logo-text {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.22em;
}

.card-face.front {
  transform: rotateY(180deg);
  background: radial-gradient(circle at top, #1f2937, #020617);
}

.role-description {
  margin-bottom: 0.3rem;
  font-size: 0.78rem;
  color: #9ca3af;
  text-align: center;
  padding-inline: 0.5rem;
}

.role-chip {
  padding: 0.25rem 0.75rem;
  border-radius: 999px;
  border: 1px solid rgba(248, 250, 252, 0.25);
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  margin-bottom: 0.4rem;
}

.player-name {
  font-weight: 600;
}

.phase-section {
  margin-top: 1.5rem;
  padding: 1rem 1rem 1.1rem;
  border-radius: 16px;
  background: radial-gradient(circle at top left, rgba(15, 23, 42, 0.95), rgba(2, 6, 23, 0.95));
  border: 1px solid rgba(148, 163, 184, 0.5);
}

.phase-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.4rem;
}

.phase-badge,
.round-badge {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.14em;
}

.phase-badge {
  color: #f9fafb;
}

.round-badge {
  color: #9ca3af;
}

.phase-text {
  margin: 0 0 0.75rem;
  font-size: 0.9rem;
  color: #e5e7eb;
}

.kill-controls {
  flex: 1;
}

.kill-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-top: 0.4rem;
}

.pill-button {
  border-radius: 999px;
  border: 1px solid rgba(148, 163, 184, 0.6);
  background: rgba(15, 23, 42, 0.9);
  color: #e5e7eb;
  padding: 0.25rem 0.7rem;
  font-size: 0.85rem;
  cursor: pointer;
}

.pill-button.dead {
  opacity: 0.4;
  text-decoration: line-through;
}

.bottom-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1.5rem;
  margin-top: 0.75rem;
  flex-wrap: wrap;
}

.win-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.86);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 50;
  backdrop-filter: blur(8px);
}

.win-modal {
  background: radial-gradient(circle at top, #111827, #020617);
  border-radius: 24px;
  padding: 2rem 2.5rem;
  box-shadow:
    0 20px 45px rgba(0, 0, 0, 0.85),
    0 0 0 1px rgba(148, 163, 184, 0.5);
  text-align: center;
}

.win-modal h2 {
  margin: 0 0 1.25rem;
  font-size: 1.8rem;
}

.summary-columns {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1.5rem;
}

.summary-list {
  list-style: none;
  padding: 0;
  margin: 0.4rem 0 0;
}

.summary-list li {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.9rem;
  padding: 0.35rem 0;
}

.summary-list .name {
  font-weight: 500;
}

.role-tag {
  padding: 0.15rem 0.6rem;
  border-radius: 999px;
  border: 1px solid rgba(148, 163, 184, 0.9);
  font-size: 0.75rem;
}

.status {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.14em;
}

.status.alive {
  color: #4ade80;
}

.status.dead {
  color: #f97316;
}

body[data-theme='light'] .app-shell {
  background: radial-gradient(circle at top, #e5e7eb, #f8fafc 52%, #ffffff);
  color: #111827;
}

body[data-theme='light'] .panel {
  background: rgba(255, 255, 255, 0.96);
  box-shadow:
    0 18px 45px rgba(15, 23, 42, 0.15),
    0 0 0 1px rgba(100, 116, 139, 0.18);
}

body[data-theme='light'] .subtitle,
body[data-theme='light'] .helper {
  color: #4b5563;
}

.avatar-select,
.will-input,
.settings-panel input[type='number'],
.settings-panel select {
  border-radius: 10px;
  border: 1px solid rgba(148, 163, 184, 0.6);
  background: rgba(15, 23, 42, 0.9);
  color: #f9fafb;
  padding: 0.45rem 0.55rem;
}

body[data-theme='light'] .avatar-select,
body[data-theme='light'] .will-input,
body[data-theme='light'] .settings-panel input[type='number'],
body[data-theme='light'] .settings-panel select {
  background: #ffffff;
  color: #111827;
}

.settings-row {
  display: flex;
  gap: 0.6rem;
  margin-top: 0.9rem;
  flex-wrap: wrap;
}

.settings-panel {
  margin-top: 0.8rem;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  gap: 0.55rem;
  padding: 0.9rem;
  border-radius: 12px;
  border: 1px solid rgba(148, 163, 184, 0.45);
  background: rgba(15, 23, 42, 0.6);
}

.settings-panel label {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.85rem;
}

.phase-transition-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(2, 6, 23, 0.88);
  color: #f9fafb;
  font-size: 2rem;
  letter-spacing: 0.1em;
  z-index: 70;
  animation: phase-fade 0.85s ease-in-out forwards;
}

@keyframes phase-fade {
  from {
    opacity: 0;
  }
  40% {
    opacity: 1;
  }
  to {
    opacity: 0;
  }
}

@media (max-width: 900px) {
  .hero-card {
    grid-template-columns: minmax(0, 1fr);
  }
}

@media (max-width: 640px) {
  .panel,
  .hero-card {
    padding: 1.75rem 1.4rem;
    border-radius: 20px;
  }

  .mode-select-content {
    padding: 1.5rem 1rem;
  }

  .mode-select-title {
    font-size: 2rem;
  }

  .mode-cards {
    flex-direction: column;
    align-items: center;
  }

  .mode-card {
    width: 100%;
    max-width: 280px;
  }

  .hero-text .hero-title,
  .landing-content .hero-title {
    font-size: 3.2rem;
  }

  .panel-header {
    flex-direction: column;
    align-items: flex-start;
  }

  .badge-row {
    flex-direction: row;
  }

  .options-row {
    flex-direction: column;
    align-items: stretch;
  }
}

